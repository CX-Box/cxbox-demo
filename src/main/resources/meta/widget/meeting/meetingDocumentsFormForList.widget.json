      "label": "Document Type",
      "key": "document",
      "type": "dictionary"
    },
    {
      "label": "Department",
      "key": "briefing",
      "type": "dictionary"
    },
    {
      "label": "File",
      "key": "file",
      "type": "fileUpload",
      "fileIdKey": "fileId",
      "preview": {
        "enabled": true
      }
    },
    {
      "label": "File Encrypt and Sign",
      "key": "fileEncryptAndSign",
      "type": "fileUpload",
      "fileIdKey": "fileEncryptAndSignId"
    },
    {
      "label": "File Encrypted",
      "key": "fileEncryptRO",
      "type": "fileUpload",
      "fileIdKey": "fileEncryptROId"
    },
    {
      "label": "File Signed",
      "key": "fileSignRO",
      "type": "fileUpload",
      "fileIdKey": "fileSignROId"
    },
    {
      "label": "File Encrypted",
      "key": "fileEncrypt",
      "type": "hidden",
      "fileIdKey": "fileEncryptId"
    },
    {
      "label": "File Signed",
      "key": "fileSign",
      "type": "hidden",
      "fileIdKey": "fileSignId"
    },
    {
      "label": "File Signed Name",
      "key": "NAME_FILE_OVERRIDE_SIGN",
      "type": "hidden"
    },
    {
      "label": "File Encrypt Name",
      "key": "NAME_FILE_OVERRIDE_ENCRYPT",
      "type": "hidden"
    },
    {
      "label": "Notes",
      "key": "notes",
      "type": "input"
    }
  ],
  "options": {
    "cryptoGenerator": [
