      "type": "fileUpload",
      "fileIdKey": "fileEncryptAndSignId"
    },
    {
      "title": "Status",
      "key": "status",
      "type": "dictionary",
      "bgColorKey": "color"
    },
    {
      "title": "Notes",
      "key": "notes",
      "type": "input"
    },
    {
      "title": "File Encrypted",
      "key": "fileEncrypt",
      "type": "hidden",
      "fileIdKey": "fileEncryptId"
    },
    {
      "title": "File Signed",
      "key": "fileSign",
      "type": "hidden",
      "fileIdKey": "fileSignId"
    },
    {
      "title": "File Signed Name",
      "key": "NAME_FILE_OVERRIDE_SIGN",
      "type": "hidden"
    },
    {
      "title": "File Encrypt Name",
      "key": "NAME_FILE_OVERRIDE_ENCRYPT",
      "type": "hidden"
    }
  ],
  "options": {
    "groupingHierarchy": {
      "counterMode": "always",
      "fields": [
        "document",
        "briefing"
      ]
    },
    "buttons": [
